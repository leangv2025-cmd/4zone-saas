# 4Zone Backend — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to GitHub!

# ================================
# GOOGLE CLOUD AI APIs
# ================================
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# For Google Cloud Text-to-Speech (Service Account JSON)
# Either use the JSON string directly or a file path:
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
# OR: GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

GOOGLE_CLOUD_PROJECT_ID=your-project-id

# ================================
# APP CONFIG
# ================================
PORT=3001
NODE_ENV=production

# JWT Secret — use a long random string in production!
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_very_long_random_secret_string

# ================================
# FRONTEND URLS (for CORS)
# ================================
FRONTEND_URL=https://4zone.store
APP_URL=https://app.4zone.store

# ================================
# FUTURE INTEGRATIONS (coming soon)
# ================================
# ELEVENLABS_API_KEY=
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# DATABASE_URL=postgresql://...
